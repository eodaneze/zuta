<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap');
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: 'Inter', sans-serif;
        font-weight: 300;
      }
      .container {
        width: 80%;
        margin: auto;
      }
      .header {
        height: 110px;
        width: 100%;
        display: flex;
        justify-content: flex-start;
        align-items: center;
        background: linear-gradient(rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.7)),
          url('https://zecconsultin.com/spellamart-banner-2.jpg') no-repeat center
            center;
        background-size: 677px;
        border-radius: 5px;
      }
      h2 {
        color:  #2563eb;
        font-size: 28px;
        margin: 28px 0;
      }
      h3 {
        font-size: 18px;
        margin-top: 54px;
        margin-bottom: 20px;
      }
      p {
        font-size: 14px;
        line-height: 1.5;
      }
      .code-box {
        margin: 20px 0;
        padding: 15px;
        background: #f7f7f7;
        border: 1px dashed #ccc;
        font-size: 24px;
        font-weight: 700;
        letter-spacing: 6px;
        text-align: center;
      }
    </style>

    <title>Zutaonline Password Reset</title>
  </head>
  <body>
    <section class="main">
      <div class="header">
        <div class="container"></div>
      </div>

      <div class="content container">
        <h3>Hello Awesome {{name}} 😃</h3>

        <p>
          You recently requested to reset your Zutaonline account password.
          Please use the verification code below to continue with your password
          reset.
        </p>

        <h2><u>{{code}}</u></h2>

        <p>
          Enter this code in the password reset screen to set a new password for
          your account.
        </p>

        <br />

        <p>
          <strong>Note:</strong> This code will expire in <b>10 minutes</b>. If
          the code expires, you’ll need to request a new one.
        </p>

        <br />
        <hr />
        <br />

        <i>
          PS: This email was sent because a password reset was requested for your
          account. If you did not make this request, please ignore this email —
          your password will remain unchanged.
        </i>

        <br /><br />

        <p>
          Warmest regards,<br />
          <strong>Zutaonline Team</strong>
        </p>
      </div>
    </section>
  </body>
</html>
